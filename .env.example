# Copy this file to .env and fill in real values.
# See README.md for full setup instructions.

# --- Database (PostgreSQL — local Postgres or a Supabase project both work) ---
DATABASE_URL="postgresql://user:password@localhost:5432/socialpilot?schema=public"

# --- App auth / security (required) ---
# Generate each with: openssl rand -hex 32
AUTH_SECRET=""
ENCRYPTION_KEY=""
# Generate with: openssl rand -hex 16 — verifies requests to /api/cron/publish-scheduled
CRON_SECRET=""

# --- App URL (used to build OAuth redirect URIs) ---
APP_URL="http://localhost:3000"

# --- Local media storage (optional — defaults to ./public/uploads) ---
UPLOAD_DIR=""

# --- Instagram (via Facebook Login for Business + Instagram Graph API) ---
# Create an app at https://developers.facebook.com/apps
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""
INSTAGRAM_REDIRECT_URI="http://localhost:3000/api/social/callback/instagram"

# --- Facebook (Graph API, Page publishing) ---
# Create an app at https://developers.facebook.com/apps
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_REDIRECT_URI="http://localhost:3000/api/social/callback/facebook"

# --- TikTok (Content Posting API) ---
# Create an app at https://developers.tiktok.com/apps
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_REDIRECT_URI="http://localhost:3000/api/social/callback/tiktok"

# --- LinkedIn (UGC Posts API) ---
# Create an app at https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="http://localhost:3000/api/social/callback/linkedin"

# --- X / Twitter (API v2, OAuth2 with PKCE) ---
# Create an app at https://developer.x.com/en/portal/dashboard
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""
TWITTER_REDIRECT_URI="http://localhost:3000/api/social/callback/twitter"

# --- YouTube Shorts (YouTube Data API v3, Google OAuth) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_REDIRECT_URI="http://localhost:3000/api/social/callback/youtube"
